{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "app" : {
    "name": "Todo API"
  },
  "auth": {
    "issuer": "todo",
    "audience": "todo-api",
    "signingKey": "super-duper-secret-key-min-32-chars",
    "expiry": "01:00:00"
  },
  "postgres": {
    "connectionString" : "Host=localhost;Port=5435;Database=todo;Username=postgres;Password=postgres"
  },
  "emailConfirmation": {
    "issuer": "todo-email",
    "audience": "todo-email-confirmation",
    "signingKey": "super-duper-email-secret-key-min-32-chars",
    "frontendConfirmUrl": "https://your-frontend-domain/confirm-email",
    "expiry": "1.00:00:00"
  },
  "smtp": {
    "host": "email-smtp.eu-central-1.amazonaws.com",
    "port": 587,
    "username": "replace-with-ses-smtp-username",
    "password": "replace-with-ses-smtp-password",
    "fromEmail": "noreply@your-domain.com",
    "fromName": "Todo App",
    "useSsl": true
  },
  "cors": {
    "allowedOrigins": [
      "https://your-frontend-domain"
    ]
  }
}
